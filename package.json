{
  "name": "pjf-bot",
  "version": "1.0.0",
  "description": "Bot de consulta de expedientes PJF - Juicio en Línea",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node scripts/install-playwright-browsers.js && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "pjf",
    "expedientes",
    "electron",
    "playwright"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "playwright": "^1.58.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.pjf.bot",
    "productName": "ETHOS - PJF Bot Expedientes",
    "icon": "assets/icon.ico",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      { "from": "playwright-browsers", "to": "playwright-browsers", "filter": ["**/*"] }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
